<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EnergyOptimiser Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .card { background: #1e293b; border: 1px solid #334155; border-radius: 1rem; padding: 1.5rem; }
        .input-field { background: #0f172a; border: 1px solid #475569; border-radius: 0.5rem; padding: 0.5rem; width: 100%; color: white; font-size: 0.875rem; }
        .btn-primary { background: #10b981; color: white; padding: 0.75rem; border-radius: 0.5rem; font-weight: bold; width: 100%; transition: 0.2s; border: none; cursor: pointer; }
        .btn-primary:hover { background: #059669; }
        .btn-secondary { background: #334155; color: white; padding: 0.75rem; border-radius: 0.5rem; font-weight: bold; width: 100%; transition: 0.2s; border: none; cursor: pointer; }
        .badge { padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.7rem; font-weight: bold; }
        .help-text { color: #94a3b8; font-size: 0.7rem; margin-top: 0.35rem; line-height: 1.4; display: block; }
        .section-title { font-size: 1.125rem; font-weight: 800; color: #10b981; margin-bottom: 1rem; border-bottom: 1px solid #334155; padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; }
        .animate-fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-slate-900 text-white font-sans min-h-screen">
    <nav class="bg-slate-800 p-4 border-b border-slate-700 sticky top-0 z-50 shadow-2xl">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold flex items-center gap-2">
                <span class="text-emerald-400 text-2xl">⚡</span> EnergyOptimiser Admin <span class="text-[10px] font-normal text-slate-400 bg-slate-700 px-2 py-1 rounded ml-2">v2026.3.19</span>
            </h1>
            <div class="flex gap-6">
                <button onclick="showPage('dashboard')" class="text-slate-300 hover:text-emerald-400 font-bold tracking-tight">Dashboard</button>
                <button onclick="showPage('config')" class="text-slate-300 hover:text-emerald-400 font-bold tracking-tight">⚙️ Instellingen</button>
            </div>
        </div>
    </nav>

    <main class="container mx-auto p-6 max-w-7xl">
        <!-- Dashboard Page -->
        <div id="page-dashboard" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div class="card shadow-lg border-l-4 border-emerald-500">
                    <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Status</p>
                    <h2 id="status-enabled" class="text-xl font-black italic text-rose-400">Laden...</h2>
                </div>
                <div class="card shadow-lg">
                    <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Batterij SOC</p>
                    <h2 id="status-soc" class="text-xl font-black text-emerald-400">--%</h2>
                </div>
                <div class="card shadow-lg">
                    <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Zon Vandaag (est)</p>
                    <h2 id="status-solar" class="text-xl font-black text-yellow-400">0.0 kWh</h2>
                </div>
                <div class="card shadow-lg">
                    <p class="text-slate-400 text-[10px] uppercase font-bold mb-1">Prijzen Bron</p>
                    <h2 class="text-xl font-black text-blue-400">EnergyZero</h2>
                </div>
            </div>

            <div class="card shadow-xl">
                <h3 class="text-sm font-bold text-slate-400 mb-4">📈 24-uurs Planning (EnergyZero NL incl. BTW)</h3>
                <div class="h-[400px] relative">
                    <canvas id="mainChart"></canvas>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 pb-10">
                <div class="card overflow-hidden shadow-lg">
                    <h3 class="text-lg font-black mb-4 border-b border-slate-700 pb-2">📋 Details per Uur</h3>
                    <div class="overflow-x-auto max-h-[500px] overflow-y-auto pr-2">
                        <table class="w-full text-left text-xs">
                            <thead class="sticky top-0 bg-slate-800 z-10">
                                <tr class="text-slate-400 border-b border-slate-700">
                                    <th class="py-3 px-2">Tijd</th>
                                    <th class="py-3 px-2">Prijs (€)</th>
                                    <th class="py-3 px-2">Zon (kW)</th>
                                    <th class="py-3 px-2">Grid-Laden</th>
                                </tr>
                            </thead>
                            <tbody id="forecast-table" class="divide-y divide-slate-800"></tbody>
                        </table>
                    </div>
                </div>
                <div class="card shadow-lg">
                    <h3 class="text-lg font-black mb-4 border-b border-slate-700 pb-2">🔌 Actieve Omvormer Slots</h3>
                    <div id="slots-container" class="space-y-3"></div>
                </div>
            </div>
        </div>

        <!-- Config Page -->
        <div id="page-config" class="hidden space-y-6 animate-fade-in pb-24">
            <div class="flex flex-col md:flex-row gap-4 mb-8 sticky top-20 z-40 bg-slate-900/95 p-4 rounded-xl border border-slate-700 backdrop-blur shadow-2xl">
                <div class="flex-1">
                    <h2 class="text-xl font-black text-white">Systeemconfiguratie</h2>
                    <p class="text-xs text-slate-400">Vul alle onderstaande velden nauwkeurig in voor een optimale werking.</p>
                </div>
                <div class="flex gap-3">
                    <button onclick="testRun()" id="testBtn" class="btn-secondary px-6">🧪 Test Run</button>
                    <button type="submit" form="configForm" id="saveBtn" class="btn-primary px-10">💾 Instellingen Opslaan</button>
                </div>
            </div>

            <form id="configForm" class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div class="space-y-8">
                    <div class="card">
                        <div class="section-title"><span>⚙️</span> Basis Instellingen</div>
                        <div class="space-y-5">
                            <div class="flex items-center justify-between p-4 bg-slate-800/50 rounded-xl border border-slate-700 shadow-inner">
                                <div class="max-w-[75%]">
                                    <p class="font-black text-sm">Optimalisatie Inschakelen</p>
                                    <span class="help-text">Wanneer dit aan staat, zal het programma elk uur de omvormer instellingen (registers) overschrijven in Home Assistant. Zet dit UIT als je handmatig controle wilt behouden.</span>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" name="enabled" id="config-enabled" class="sr-only peer">
                                    <div class="w-14 h-7 bg-slate-700 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-emerald-500 after:content-[''] after:absolute after:top-1 after:left-[4px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                                </label>
                            </div>
                            
                            <div>
                                <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Marktregio (EPEX Spot NL)</label>
                                <input type="text" name="market_area" class="input-field" placeholder="bijv. NL">
                                <span class="help-text">Vul 'NL' in voor de Nederlandse EPEX Spot markt. Deze data wordt opgehaald via de EnergyZero API en is de standaard voor dynamische contracten in Nederland.</span>
                            </div>

                            <div>
                                <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Strategie</label>
                                <select name="strategy" class="input-field">
                                    <option value="Maximize Profit">Winstmaximalisatie (Prijs-arbitrage)</option>
                                    <option value="Maximize Self-Consumption">Eigen Verbruik Maximaliseren</option>
                                    <option value="Zero on the Meter">0 op de Meter (Minimaal Netgebruik)</option>
                                </select>
                                <span class="help-text"><b>Winst:</b> Laden bij laagste prijs, ontladen bij hoogste. <b>Eigen verbruik:</b> Houdt accu vol voor eigen gebruik. <b>0 op de Meter:</b> Vermijdt het net volledig (behalve bij gratis stroom).</span>
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Update Interval (min)</label>
                                    <input type="number" name="update_interval_minutes" class="input-field" min="1">
                                    <span class="help-text">Hoe vaak per uur het systeem de registers bijwerkt. Advies: 60.</span>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Valuta</label>
                                    <input type="text" name="currency" class="input-field" value="EUR" readonly>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-lg border border-yellow-500/20">
                        <div class="section-title text-yellow-400"><span>☀️</span> Zonnepanelen Inrichting</div>
                        <div class="space-y-5">
                            <div class="flex items-center justify-between p-4 bg-slate-800/50 rounded-xl border border-slate-700 shadow-inner">
                                <div class="max-w-[75%]">
                                    <p class="font-black text-sm">Zon-voorspelling Gebruiken</p>
                                    <span class="help-text">Schakel dit in om het laden vanaf het net te blokkeren als er vandaag genoeg zon wordt verwacht om je accu gratis te vullen.</span>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" name="solar_enabled" id="config-solar-enabled" class="sr-only peer">
                                    <div class="w-14 h-7 bg-slate-700 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-yellow-500 after:content-[''] after:absolute after:top-1 after:left-[4px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                                </label>
                            </div>
                            <div id="solar-arrays-container" class="space-y-4"></div>
                            <button type="button" onclick="addSolarArray()" class="text-xs font-black bg-slate-700 hover:bg-slate-600 p-3 rounded-lg w-full transition border border-slate-600 border-dashed text-emerald-400">+ EXTRA SET ZONNEPANELEN TOEVOEGEN</button>
                            <span class="help-text italic text-center text-[10px]">Voeg hier alle dakvlakken toe (bijv. Voorzijde en Achterzijde) voor een accurate berekening. 180° = Zuid, 90° = Oost, 270° = West.</span>
                        </div>
                    </div>
                </div>

                <div class="space-y-8">
                    <div class="card">
                        <div class="section-title"><span>🔋</span> Batterij & Besluitvorming</div>
                        <div class="space-y-5">
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Capaciteit (kWh)</label>
                                    <input type="number" step="0.1" name="battery_capacity_kwh" class="input-field">
                                    <span class="help-text">De netto bruikbare inhoud van je gehele accupakket.</span>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Max Laden (kW)</label>
                                    <input type="number" step="0.1" name="max_charge_rate_kw" class="input-field">
                                    <span class="help-text">Maximale vermogen van grid-laden (bijv. 3.0 kW).</span>
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-4 border-t border-slate-700 pt-4">
                                <div>
                                    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Laad Drempel %</label>
                                    <input type="number" name="charge_threshold_pct" class="input-field">
                                    <span class="help-text">Laden vanaf net start als prijs lager is dan dit % van de gemiddelde dagprijs (bijv. 85%).</span>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Ontlaad Drempel %</label>
                                    <input type="number" name="discharge_threshold_pct" class="input-field">
                                    <span class="help-text">Ontladen (voor huis) mag als prijs hoger is dan dit % van gemiddelde dagprijs (bijv. 115%).</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-lg border border-emerald-500/20">
                        <div class="section-title"><span>🔌</span> Solarman Register Mapping</div>
                        <div class="space-y-6">
                            <div>
                                <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Batterij SOC Sensor (Home Assistant)</label>
                                <input type="text" name="solarman_battery_soc" class="input-field text-xs font-mono" placeholder="sensor.solarman_battery_soc">
                                <span class="help-text">De exacte Entiteit-ID van je batterijpercentage sensor in Home Assistant.</span>
                            </div>
                            
                            <p class="text-[10px] font-black uppercase text-emerald-400 tracking-widest border-b border-emerald-500/20 pb-1">Programma Registers (1 t/m 6)</p>
                            <div id="inverter-programs-static" class="space-y-4"></div>
                            <span class="help-text italic text-[10px]">Vul hier de Entiteit-ID's in van de Tijd, SOC % en Grid-Charge vinkjes van je Solarman integratie. Deze velden zijn permanent en blijven bewaard.</span>
                        </div>
                    </div>

                    <div class="card">
                        <div class="section-title"><span>☁️</span> Meteoserver (KNMI Data)</div>
                        <div class="space-y-4">
                            <div>
                                <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Meteoserver API Key</label>
                                <input type="password" name="meteoserver_key" class="input-field" placeholder="Je API Sleutel">
                                <span class="help-text">Vraag een gratis sleutel aan op Meteoserver.nl voor accurate zon-data.</span>
                            </div>
                            <div>
                                <label class="block text-[10px] font-black uppercase text-slate-400 mb-1">Locatie (Stad)</label>
                                <input type="text" name="meteoserver_location" class="input-field">
                                <span class="help-text">Naam van de stad voor lokale weersverwachting.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </main>

    <script>
        let chart = null;
        let configData = {};
        const apiBase = window.location.pathname.replace(/\/$/, "");

        function showPage(id) {
            document.querySelectorAll('main > div').forEach(p => p.classList.add('hidden'));
            document.getElementById('page-' + id).classList.remove('hidden');
            window.scrollTo(0,0);
        }

        async function loadData() {
            try {
                const r = await fetch(apiBase + '/api/status');
                const data = await r.json();
                configData = data.config;
                
                const enabledEl = document.getElementById('status-enabled');
                enabledEl.innerText = configData.enabled ? 'ACTIEF' : 'STANDBY (UIT)';
                enabledEl.className = 'text-xl font-black ' + (configData.enabled ? 'text-emerald-400' : 'text-rose-400');
                document.getElementById('status-soc').innerText = (data.current_soc || 0).toFixed(0) + '%';
                
                const totalSolar = data.forecast.reduce((a, b) => a + (b.solar_yield || 0), 0);
                document.getElementById('status-solar').innerText = totalSolar.toFixed(1) + ' kWh';
                document.getElementById('status-update').innerText = data.last_update ? new Date(data.last_update).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : '--:--';
                
                updateForecastTable(data.forecast);
                updateSlots(data.inverter_slots);
                updateChart(data.forecast);
                populateForm(configData);
            } catch (e) { console.error("Load failed", e); }
        }

        function populateForm(config) {
            const form = document.getElementById('configForm');
            // Basic fields
            for (let k in config) {
                if (form[k] && !['solar_arrays', 'solarman_prog_times', 'solarman_prog_socs', 'solarman_prog_grid_charges'].includes(k)) {
                    if (form[k].type === 'checkbox') form[k].checked = config[k];
                    else form[k].value = config[k];
                }
            }
            document.getElementById('config-enabled').checked = config.enabled;
            document.getElementById('config-solar-enabled').checked = config.solar_enabled;

            // Render Program Slots ONCE with stable IDs to prevent data loss
            const programsContainer = document.getElementById('inverter-programs-static');
            if (programsContainer.children.length === 0) {
                for (let i = 0; i < 6; i++) {
                    const div = document.createElement('div');
                    div.className = 'p-3 bg-slate-800/30 rounded-xl border border-slate-700/50 space-y-2 animate-fade-in';
                    div.innerHTML = `
                        <p class="text-[9px] font-black text-slate-500 uppercase tracking-tighter">Programma Slot ${i+1}</p>
                        <div class="space-y-2">
                            <div>
                                <label class="text-[8px] text-slate-500 uppercase font-bold">Tijd Entity ID</label>
                                <input type="text" id="prog-time-${i}" value="${config.solarman_prog_times[i] || ''}" class="input-field text-[10px] font-mono" placeholder="number.solarman_prog${i+1}_time">
                            </div>
                            <div class="grid grid-cols-2 gap-2">
                                <div>
                                    <label class="text-[8px] text-slate-500 uppercase font-bold">SOC % ID</label>
                                    <input type="text" id="prog-soc-${i}" value="${config.solarman_prog_socs[i] || ''}" class="input-field text-[10px] font-mono" placeholder="number.solarman_prog${i+1}_soc">
                                </div>
                                <div>
                                    <label class="text-[8px] text-slate-500 uppercase font-bold">Grid Charge ID</label>
                                    <input type="text" id="prog-grid-${i}" value="${config.solarman_prog_grid_charges[i] || ''}" class="input-field text-[10px] font-mono" placeholder="switch.solarman_prog${i+1}_grid_charge">
                                </div>
                            </div>
                        </div>
                    `;
                    programsContainer.appendChild(div);
                }
            } else {
                // Update only if not focused to avoid interrupting user input
                for (let i = 0; i < 6; i++) {
                    const t = document.getElementById(`prog-time-${i}`);
                    const s = document.getElementById(`prog-soc-${i}`);
                    const g = document.getElementById(`prog-grid-${i}`);
                    if (document.activeElement !== t) t.value = config.solarman_prog_times[i] || '';
                    if (document.activeElement !== s) s.value = config.solarman_prog_socs[i] || '';
                    if (document.activeElement !== g) g.value = config.solarman_prog_grid_charges[i] || '';
                }
            }

            // Render Solar Arrays
            const container = document.getElementById('solar-arrays-container');
            container.innerHTML = '';
            config.solar_arrays.forEach((array, i) => {
                const div = document.createElement('div');
                div.className = 'p-4 bg-slate-900/50 rounded-xl border border-slate-700 space-y-3 relative shadow-inner';
                div.innerHTML = `
                    <div class="flex justify-between items-center mb-2">
                        <input type="text" value="${array.name}" class="bg-transparent border-none text-emerald-400 font-bold array-name" placeholder="Naam (bijv. Zuid-dak)">
                        <button type="button" onclick="removeSolarArray(${i})" class="text-rose-500 text-[10px] font-black uppercase hover:underline">Verwijderen</button>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div><label class="text-[9px] font-bold text-slate-500 uppercase">kWp</label><input type="number" step="0.1" value="${array.kwp}" class="input-field text-xs array-kwp"></div>
                        <div><label class="text-[9px] font-bold text-slate-500 uppercase">Helling °</label><input type="number" value="${array.tilt}" class="input-field text-xs array-tilt"></div>
                        <div><label class="text-[9px] font-bold text-slate-500 uppercase">Azimuth °</label><input type="number" value="${array.azimuth}" class="input-field text-xs array-azimuth"></div>
                        <div><label class="text-[9px] font-bold text-slate-500 uppercase">Efficiëntie</label><input type="number" step="0.01" value="${array.efficiency}" class="input-field text-xs array-eff"></div>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function addSolarArray() {
            configData.solar_arrays.push({name: "Nieuwe set", kwp: 1.0, tilt: 35, azimuth: 180, efficiency: 0.85});
            populateForm(configData);
        }

        function removeSolarArray(i) {
            configData.solar_arrays.splice(i, 1);
            populateForm(configData);
        }

        async function testRun() {
            const btn = document.getElementById('testBtn');
            btn.innerText = '⏳ Bezig...';
            try {
                await fetch(apiBase + '/api/test_run', { method: 'POST' });
                alert('Test-run voltooid! De planning is bijgewerkt op het dashboard (geen registers gewijzigd).');
                loadData();
                showPage('dashboard');
            } catch (e) { alert('Fout: ' + e); }
            btn.innerText = '🧪 Test Run';
        }

        function updateForecastTable(forecast) {
            document.getElementById('forecast-table').innerHTML = forecast.map(f => `
                <tr class="hover:bg-slate-800/50 transition border-b border-slate-800">
                    <td class="py-3 px-2 font-mono font-bold text-[10px]">${new Date(f.time).getHours()}:00</td>
                    <td class="py-3 px-2 font-bold text-emerald-400">€${f.price.toFixed(3)}</td>
                    <td class="py-3 px-2 text-yellow-400 font-bold">${f.solar_yield.toFixed(2)}</td>
                    <td class="py-3 px-2"><span class="badge ${f.grid_charge==='on'?'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30':(f.action==='DISCHARGE'?'bg-rose-500/20 text-rose-400 border border-rose-500/30':'bg-slate-700/50 text-slate-500')}">${f.grid_charge.toUpperCase()}</span></td>
                </tr>
            `).join('');
        }

        function updateSlots(slots) {
            document.getElementById('slots-container').innerHTML = slots.map((s, i) => `
                <div class="flex items-center justify-between p-4 bg-slate-800/50 rounded-xl border border-slate-700 shadow-inner">
                    <div><p class="text-[9px] font-black uppercase text-slate-500">Slot ${i+1}</p><p class="font-mono text-emerald-400 text-xl font-black">${s.start}:00</p></div>
                    <div class="text-right"><p class="text-[10px] font-bold text-slate-200 mb-1 italic">${s.action}</p><span class="badge ${s.grid_charge==='on'?'bg-emerald-500 text-white shadow-lg shadow-emerald-900/40':'bg-slate-700 text-slate-400'}">GRID: ${s.grid_charge.toUpperCase()}</span></div>
                </div>
            `).join('');
        }

        function updateChart(forecast) {
            const ctx = document.getElementById('mainChart').getContext('2d');
            if (chart) chart.destroy();
            chart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: forecast.map(f => new Date(f.time).getHours() + ':00'),
                    datasets: [
                        { label: 'Prijs', type: 'bar', data: forecast.map(f => f.price), backgroundColor: forecast.map(f => f.grid_charge==='on'?'rgba(16, 185, 129, 0.7)':(f.action==='DISCHARGE'?'rgba(244, 63, 94, 0.7)':'rgba(71, 85, 105, 0.2)')), borderRadius: 6, yAxisID: 'y' },
                        { label: 'Zon (kW)', type: 'line', data: forecast.map(f => f.solar_yield), borderColor: '#fbbf24', tension: 0.4, yAxisID: 'y1', pointRadius: 0, fill: true, backgroundColor: 'rgba(251, 191, 36, 0.05)' }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { position: 'left', grid: { color: '#334155' }, ticks: { color: '#94a3b8' } }, y1: { position: 'right', display: false, min: 0 } } }
            });
        }

        document.getElementById('configForm').onsubmit = async (e) => {
            e.preventDefault();
            const btn = document.getElementById('saveBtn');
            btn.innerText = '⏳ Bezig met opslaan...';
            
            const config = { ...configData };
            const formData = new FormData(e.target);
            
            formData.forEach((v, k) => {
                if (['charge_threshold_pct', 'discharge_threshold_pct', 'battery_capacity_kwh', 'max_charge_rate_kw', 'update_interval_minutes'].includes(k)) config[k] = parseFloat(v);
                else if (!['enabled', 'solar_enabled'].includes(k)) config[k] = v;
            });
            
            config.enabled = document.getElementById('config-enabled').checked;
            config.solar_enabled = document.getElementById('config-solar-enabled').checked;
            
            // Explicitly collect Registers from stable IDs to guarantee no data loss
            config.solarman_prog_times = [];
            config.solarman_prog_socs = [];
            config.solarman_prog_grid_charges = [];
            for (let i = 0; i < 6; i++) {
                config.solarman_prog_times.push(document.getElementById(`prog-time-${i}`).value);
                config.solarman_prog_socs.push(document.getElementById(`prog-soc-${i}`).value);
                config.solarman_prog_grid_charges.push(document.getElementById(`prog-grid-${i}`).value);
            }

            // Collect Solar Arrays
            config.solar_arrays = Array.from(document.getElementById('solar-arrays-container').children).map(div => ({
                name: div.querySelector('.array-name').value,
                kwp: parseFloat(div.querySelector('.array-kwp').value),
                tilt: parseFloat(div.querySelector('.array-tilt').value),
                azimuth: parseFloat(div.querySelector('.array-azimuth').value),
                efficiency: parseFloat(div.querySelector('.array-eff').value)
            }));

            const response = await fetch(apiBase + '/api/config', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(config) });
            btn.innerText = '💾 Instellingen Opslaan';
            if (response.ok) { alert('Instellingen succesvol opgeslagen!'); loadData(); }
            else { alert('Fout bij opslaan!'); }
        };

        setInterval(loadData, 60000);
        loadData();
    </script>
</body>
</html>
